{
  "name": "next-start",
  "version": "0.0.1",
  "private": false,
  "keywords": [
    "next",
    "nextjs",
    "react",
    "starter",
    "tailwindcss",
    "template",
    "typescript"
  ],
  "homepage": "https://github.com/DobroslavRadosavljevic/next-start#readme",
  "bugs": {
    "url": "https://github.com/DobroslavRadosavljevic/next-start/issues"
  },
  "license": "MIT",
  "author": "Dobroslav Radosavljevic",
  "repository": {
    "type": "git",
    "url": "https://github.com/DobroslavRadosavljevic/next-start.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/DobroslavRadosavljevic"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "ultracite check",
    "prepare": "husky",
    "lint:staged": "bun lint-staged",
    "format": "ultracite fix",
    "typegen": "next typegen",
    "pretypecheck": "bun run typegen",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@elysiajs/eden": "1.4.8",
    "@elysiajs/openapi": "1.4.14",
    "@kuzenbo/charts": "0.0.6",
    "@kuzenbo/core": "0.0.6",
    "@kuzenbo/hooks": "0.0.6",
    "@kuzenbo/notifications": "0.0.6",
    "@kuzenbo/styles": "0.0.6",
    "@kuzenbo/theme": "0.0.6",
    "@sentry/nextjs": "10.40.0",
    "@t3-oss/env-nextjs": "0.13.10",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "elysia": "1.4.26",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "schema-dts": "1.1.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@tailwindcss/postcss": "4.2.1",
    "@types/bun": "1.3.9",
    "@types/node": "25.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260228.1",
    "husky": "9.1.7",
    "lint-staged": "16.3.0",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "ultracite": "7.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "bun ultracite fix",
      "bun ultracite check"
    ]
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@sentry/cli",
    "sharp",
    "unrs-resolver"
  ]
}
