# Site URL: auto-derived from Vercel system vars (VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL).
# Enable "Automatically expose System Environment Variables" in Vercel project settings.
# Local dev uses http://localhost:3000.

NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-url
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token